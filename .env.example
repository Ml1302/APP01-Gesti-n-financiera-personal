# Micro-ERP Financiero - Variables de Entorno

# --- Backend ---
# Puerto del servidor backend
PORT=3000

# --- Base de Datos ---
DB_HOST=localhost
DB_PORT=1521
DB_NAME=XE
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña

# --- Autenticación ---
