# --- Google Gemini API (NLP) ---
GEMINI_API_KEY=tu_api_key_de_gemini

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# --- Moneda Base ---
BASE_CURRENCY=PEN
